#!/usr/bin/env bash


# Start a new session (tmux or zellij) with regular dev dependencies


set -o errexit


source "$(dirname "$0")/bash-std"


function options
{
    cat <<EOF
session-name; Name for the new tmux/zellij session
--zellij,-z; Use zellij instead of tmux
--verbose,-v; Verbose output
EOF
}


bash-std-application-init "$@" < <( options ) ||
    die "Failed to parse command line args"
bash-std-set-verbose


session_name="$options_session_name"
[[ -n "$session_name" ]] || die "session-name is required"


# Determine which venv to activate, starting with the active venv (if any),
# falling back on the HQ default
venv_path="$VIRTUAL_ENV"
[[ -n "$venv_path" ]] || venv_path="$HQ_VENV"
[[ -n "$venv_path" ]] || die "Could not determine virtual env path from active venv or HQ_VENV"


# Before we go launching emacs, display a warning if there is already an emacs server
# running (in an unknown environment)
ps aux | grep -v "grep" | grep "emacs --daemon" >/dev/null &&
    say "${fmt_yellow}WARNING${fmt_reset}: emacs server is already running, so may not be in venv: $venv_path"


if (( options_zellij )); then

    # Generate a temporary layout file and start the session
    layout_file="$(mktemp /tmp/abyss-trinity-XXXXXX.kdl)"
    trap "rm -f '$layout_file'" EXIT

    cat > "$layout_file" << EOF
layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
    }
    tab name="edit" {
        pane cwd="$HOME/src/abyss" {
            command "bash"
            args "-c" "zellij action rename-session '${session_name}'; source ${venv_path}/bin/activate && em"
        }
    }
    tab name="claude" {
        pane cwd="$HOME/src/abyss" {
            command "bash"
            args "-c" "source ${venv_path}/bin/activate && sleep 2 && claude --ide"
        }
    }
    tab name="repl" {
        pane {
            command "bash"
            args "-c" "source ${venv_path}/bin/activate && ipython"
        }
    }
    tab name="bedrock" {
        pane cwd="$HOME/src/abyss/abyss-bedrock"
    }
    tab name="deepl" {
        pane cwd="$HOME/src/abyss/deep-learning"
    }
    tab name="fabric" {
        pane cwd="$HOME/src/abyss/abyss-fabric"
    }
}
EOF

    say "Layout: $(cat "$layout_file")" >&2
    zellij --layout "$layout_file"

else

    SOURCE_VENV="source \"$venv_path/bin/activate\""

    # Start tmux server
    tmux start

    # Create a new session with the first window for emacs
    tmux new-session \
         -ds "$session_name" \
         -n edit \
         -c "$HOME/src/abyss" \
         "$SOURCE_VENV && em"

    tmux new-window -a \
         -t "$session_name:edit" \
         -n claude \
         -c "$HOME/src/abyss" \
         "$SOURCE_VENV && sleep 2 && claude --ide"

    tmux new-window -a \
         -t "$session_name:claude" \
         -n repl \
         "$SOURCE_VENV && ipython"

    tmux new-window -a \
         -t "$session_name:claude" \
         -n bedrock \
         -c "$HOME/src/abyss/abyss-bedrock"
    tmux new-window -a \
         -t "$session_name:bedrock" \
         -n deepl \
         -c "$HOME/src/abyss/deep-learning"
    tmux new-window -a \
         -t "$session_name:deepl" \
         -n fabric \
         -c "$HOME/src/abyss/abyss-fabric"

    tmux attach -t "$session_name"

fi
