[Unit]
Description=Dashboard API
After=network.target

[Service]
Environment=PATH=/home/hamish/venvs/current/bin:/home/hamish/.local/bin:/usr/local/bin:/usr/bin:/bin
WorkingDirectory=/home/hamish/hq
ExecStart=/home/hamish/hq/hq/gui/dashboard/lib/server.py
User=hamish
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
