notes: |
  Pour initial boiling water over tea leaves to bloom, then pour remaining water in teapot, then steep wet leaves
components:
  - name: black tea
    yield: per 100g water
    ingredients:
      - item: tea leaves
        mass: 1.3
      - item: water
        mass: 100
    steps:
      - brew at 84°C for 4.5 min
  - name: black tea with milk
    yield: per 100g water (add 0.2g tea for milky)
    ingredients:
      - item: tea leaves
        mass: 1.5
      - item: water
        mass: 100
    steps:
      - brew at 90°C for 4.5 min
  - name: black tea milky (alternative measure)
    yield: 200g water
    ingredients:
      - item: tea leaves
        mass: 3.5
      - item: water
        mass: 200
      - item: coarse chai
        mass: 0.25
        optional: true
        note: per 100g water
    steps:
      - brew at 90°C for 4.5 min
