yield: per 300g meat
ingredients:
  - item: duck breast
    mass: 300
    basis: true
  - item: black pepper
    mass: 1
  - item: white pepper
    mass: 0.5
  - item: salt
    mass: 3
  - item: 5 spice
    mass: 1.5
steps:
  - separate fat from breast
  - score duck breast and fat
  - heat pan to 200°C
  - cook until internal temp 56°C, pull at 48°C
  - rest in foil
