yield: for a 650g rack
ingredients:
  - item: pork ribs
    mass: 650
    basis: true
components:
  - name: wetting agents
    ingredients:
      - item: apple cider
        mass: 90
        note: remainder of can, in sprayer
      - item: liquid smoke dilution
        mass: 60
        note: from 3.5g liquid smoke, in sprayer
  - name: rub
    ingredients:
      - item: smoked salt
        mass: 5
      - item: coarse black pepper
        mass: 5
      - item: paprika
        mass: 1.8
        qty: 1
        unit: tsp
      - item: garlic powder
        mass: 3
        qty: 1
        unit: tsp
      - item: onion powder
        mass: 2.3
        qty: 0.75
        unit: tsp
      - item: cayenne
        mass: 0.2
        qty: 0.25
        unit: tsp
      - item: dried thyme
        mass: 0.8
        qty: 0.75
        unit: tsp
      - item: dried oregano
        qty: 0.75
        unit: tsp
    notes: |
      2:1 meat:bone side ratio
  - name: bbq sauce
    ingredients:
      - item: apple cider vinegar
        mass: 65
      - item: tomato sauce
        mass: 180
        qty: 0.75
        unit: cup
      - item: apple cider
        mass: 65
      - item: molasses
        mass: 27
        qty: 0.75
        unit: tbsp
      - item: brown sugar
        mass: 22
        qty: 0.167
        unit: cup
        note: 1/6 cup
      - item: mustard powder
        mass: 2.8
        qty: 1
        unit: tsp
      - item: garlic powder
        mass: 2.3
        qty: 0.75
        unit: tsp
      - item: worcestershire sauce
        mass: 5.5
        qty: 1
        unit: tsp
      - item: salt
        mass: 2.4
        qty: 0.5
        unit: tsp
      - item: black pepper
        mass: 0.7
        qty: 0.5
        unit: tsp
      - item: cayenne
        mass: 0.5
        qty: 0.5
        unit: tsp
        optional: true
        note: for spice
  - name: prep
    steps:
      - pat dry
      - remove membrane
      - spray with curing salt dilution (2g into 60g water, then 10g diluted mix into another 60g water)
      - apply rub starting with salt then remainder of mix (2:1 meat:bone side)
      - refrigerate for 30 mins - 4 hours (overnight okay if no curing salt used)
  - name: sauce
    steps:
      - place all ingredients in saucepan and simmer for 45 mins (or until thickened)
      - stir occasionally
  - name: cooking
    steps:
      - oven to 135°C
      - place water-filled pan below to catch drippings
      - spray with liquid smoke
      - into oven on wire rack until surface temp reaches 65°C (roughly 1 hour)
      - drop temp to 120°C if temp climbs too fast
      - spray with apple cider then liquid smoke again
      - back into oven until surface temp reaches 82°C (roughly another hour)
      - repeat spray with cider then smoke
      - back into oven until core temp reaches 96°C (roughly another hour)
      - oven down to 120°C
      - ribs onto foil + baking paper-lined tray, bone side up
      - baste topside then bake for 10 mins
      - flip and baste topside every 10 mins until ribs have a thick glaze (up to an hour)
      - rest until core temp is down to 65°C
      - slice and serve
