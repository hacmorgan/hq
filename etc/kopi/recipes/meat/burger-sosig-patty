yield: per 100g of mince
ingredients:
  - item: mince
    mass: 100
    basis: true
  - item: onion salt
    mass: 2
    optional: true
    note: 'optional: half-cut with plain salt'
  - item: white pepper
    mass: 0.7
    note: sosig only
  - item: oregano
    mass: 0.15
    optional: true
  - item: tarragon
    mass: 0.2
    optional: true
  - item: fresh chopped parsley
    mass: 1
    optional: true
notes: |
  Mincing meat ratio:
  Chuck : Brisket : Short rib
    2   :    1    :     1
components:
  - name: mincing meat
    steps:
      - chop into smallish cubes and coat in seasoning before mincing
      - keep strands from mincer parallel as they come out of mincer
      - wrap parallel strands into a log to compact them
      - chill to set
      - cut patties from log
  - name: pre-minced meat
    steps:
      - cover top surface with seasoning
      - like damascus steel, cut in half, stack squish, repeat
