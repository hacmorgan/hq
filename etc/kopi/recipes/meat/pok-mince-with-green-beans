yield: for 450g pork mince
ingredients:
  - item: pork mince
    mass: 450
    basis: true
  - item: green beans
    note: chop ends off and cut into bite-sized pieces
  - item: brown onion
    qty: 1
    unit: ea
    note: chopped
  - item: garlic
    note: a few cloves
  - item: ginger
    mass: 7
    note: chopped
  - item: oil
    qty: 1.5
    unit: tbsp
components:
  - name: sauce
    ingredients:
      - item: soy sauce
        mass: 18
        qty: 1
        unit: tbsp
      - item: dark soy
        mass: 15
        optional: true
      - item: shaoxing wine
        mass: 15
        qty: 1
        unit: tbsp
      - item: sugar
        mass: 5
        qty: 1
        unit: tsp
      - item: pun chun
        mass: 9
        qty: 1.5
        unit: tsp
        note: chilli garlic sauce
steps:
  - pan to 230°C
  - sear beans in 1.5 tbsp oil for 2.5 mins, tossing every 30s after 1 min
  - remove beans
  - pan down to 160°C
  - add brown onion, chopped
  - then add a few cloves of garlic & 7g ginger, cook for 1 min
  - add pork, cook and break up for 2 min
  - add sauce and cook for 30s
  - add beans and stir through for 30s
