components:
  - name: full belly
    ingredients:
      - item: pork belly
        mass: 850
        basis: true
      - item: white pepper
        mass: 1.0
        note: 1:1 with black pepper
      - item: black pepper
        mass: 1.0
        note: 1:1 with white pepper
      - item: salt
        mass: 2.0
        note: flesh sides only
      - item: oil
        qty: 1
        unit: tsp
    steps:
      - dry pork belly and leave out overnight in fridge, skin side up
      - oven on to 140°C
      - oil & season (salt + pep) flesh and skin, wrap flesh in foil - start skin side down - oil, salt, pep, rub in (incl. sides) - flip onto foil, wrap around sides to confit (skin side up) - rub on 1 tsp oil - evenly sprinkle salt
      - low roast for 1.5 + 1 hrs - 1.5 hrs - take out, tighten confit foil - 1 hr
      - oven up to 240°C
      - level belly (using foil balls) so skin is flat
      - blast crackling for 20-30 mins (until golden brown and crackled)
      - rest 10 mins
  - name: fallow belly slices
    steps:
      - blanch to soften skin
      - follow above recipe for seasoning
      - bake for 30 mins at 210°C
      - reduce temp to 180°C and bake for a further 25 mins
