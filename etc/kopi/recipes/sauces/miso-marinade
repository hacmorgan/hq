notes: |
  e.g. for miso black cod
ingredients:
  - item: mirin
    mass: 50
  - item: sake
    mass: 50
  - item: miso
    mass: 100
  - item: sugar
    mass: 40
steps:
  - boil mirin and sake for 20 secs to evaporate alcohol
  - incorporate miso over low heat
  - incorporate sugar
  - cool down
  - marinate fish in marinade
