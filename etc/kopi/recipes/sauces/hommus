yield: from 1 can chickpeas
ingredients:
  - item: chickpeas
    qty: 1
    unit: can
    basis: true
  - item: chickpea water
    mass: 65
  - item: olive oil
    mass: 30
  - item: toasted sesame oil
    mass: 2.5
  - item: toasted pine nuts
    mass: 20
    note: a tiny pan-ful
  - item: toasted sesame seeds
    mass: 5
  - item: paprika
    mass: 2.5
    note: not too much
  - item: cayenne pepper
    mass: 0.3
  - item: black pepper
    mass: 1.0
  - item: white pepper
    mass: 0.5
  - item: salt
    mass: 2.2
  - item: garlic
    mass: 2.5
    note: a smallish clove, chopped
  - item: lemon
    mass: 15
    note: half a
steps:
  - combine all ingredients
  - blend until smooth
