yield: from 2 decent size lemons (375g)
ingredients:
  - item: lemon
    qty: 2
    unit: ea
    basis: true
    mass: 375
  - item: lemon zest
    mass: 1.2
    note: from one lemon
  - item: lemon juice
    mass: 113
    note: from both lemons
  - item: sugar
    mass: 50
  - item: salt
    mass: 1
  - item: cold water
    mass: 40
steps:
  - bring to boil
  - simmer for at least 30 mins
  - strain
