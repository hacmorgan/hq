components:
  - name: preparation
    steps:
      - warm bowl then dry with tea towel
  - name: base matcha
    ingredients:
      - item: matcha
        mass: 2
        note: per serve
      - item: water
        mass: 60
        note: 75°C
    steps:
      - sift matcha through sieve into bowl
      - whisk in a linear motion, not circular, and without touching the bottom, to stir up foam
  - name: latte
    ingredients:
      - item: milk
        mass: 200
      - item: sugar
        mass: 5
        note: abrasive
      - item: honey
        mass: 10
        optional: true
      - item: strawberry jam
        mass: 20
        optional: true
    steps:
      - steam milk with sugar
  - name: iced strawberry
    ingredients:
      - item: matcha
        mass: 2
        note: per serve
      - item: water
        mass: 60
        note: 75°C
      - item: milk
        mass: 150
      - item: honey
        mass: 10
      - item: strawberry mix
        mass: 40
        note: boiled down bag of frozen strawberries
    steps:
      - sift matcha through sieve into bowl
      - whisk in a linear motion, not circular, and without touching the bottom, to stir up foam
  - name: simple strawberry
    ingredients:
      - item: matcha
        mass: 2
        note: per serve
      - item: water
        mass: 60
        note: 75°C
      - item: milk
        mass: 200
      - item: strawberry nesquik
        mass: 12
      - item: strawberry jam/mix
        mass: 30
      - item: cubed ice
        optional: true
    steps:
      - sift matcha through sieve into bowl
      - whisk in a linear motion, not circular, and without touching the bottom, to stir up foam
