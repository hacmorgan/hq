components:
  - name: starter maintenance
    ingredients:
      - item: filtered water
        mass: 18
      - item: flour
        mass: 30
      - item: starter
        mass: 12
    yield: makes 30g + 18g + 50g + 30g + 20-25g + 12g
  - name: mixing
    ingredients:
      - item: bread flour
        mass: 500
        basis: true
      - item: water
        mass: 350
        qty: 70
        unit: '%'
        note: for 80:20 white:wholemeal bread flour
      - item: active stiff starter
        mass: 50
        qty: 10
        unit: '%'
      - item: salt
        mass: 10
    steps:
      - combine all ingredients in a bowl
      - wait 30 mins
      - step: do windowpane translucency test
        substeps:
          - if it tears, knead 2-3 mins, rest 10 mins, repeat
  - name: fermentation
    steps:
      - with wet hands, round the dough to make nice round surface
      - step: cover bowl and let dough rise, 6-12 hrs, but go based on criteria
        substeps:
          - 30% - 50% volume rise (use aliquot jar)
          - surface bubbles visible
          - jiggly texture when bowl shaken
          - sweet/sour smell
      - optionally stretch and fold during fermentation
  - name: shaping
    steps:
      - use batard (oval) or boulard (round)
      - sprinkle some flour over dough while still in bowl
      - flip dough from bowl onto bench (topside in bowl becomes bottomside on bench, since topside in bowl is slightly drier)
      - add some flour around edges of dough
      - step: fold (sticky) now-topside over a few times, knocking excess flour off
        substeps:
          - right to middle
          - left to middle
          - top to middle
      - roll top to middle to yield a smooth topside
      - add some flour on top
      - flip into banneton
  - name: proofing
    steps:
      - cover and refrigerate 8-96 hours to proof, or proof at room temp for 1-3 hours
      - set oven to 230°C with dutch oven inside and preheat for 30 mins
      - score & spritz loaf, optionally add rice flour
      - bake 30 mins with dutch oven lid on
      - bake until desired crust colour or until internal temp reaches 92°C (20 more mins) with lid off
