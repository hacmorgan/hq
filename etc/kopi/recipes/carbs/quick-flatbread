ingredients:
  - item: butter
    mass: 50
  - item: milk
    mass: 185
  - item: flour
    mass: 300
  - item: salt
    qty: 0.5
    unit: tsp
steps:
  - melt butter and milk in a pot
  - mix flour with salt in a bowl and add milk and butter
  - knead 2 mins
  - wrap in glad wrap and leave for 30 mins
  - cut into 6 pieces and roll into rounds
  - cook in seasoned pan
