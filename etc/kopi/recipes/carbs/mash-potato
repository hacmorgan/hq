name: mash potato
components:
  - name: infusion
    ingredients:
      - item: milk
        qty: 50
        unit: part
      - item: cream
        qty: 50
        unit: part
      - potato skins
      - item: bay leaf
        qty: 1
        unit: ea
      - item: ground nutmeg
        note: a little bit
    steps:
      - add potato skins, a bay leaf and a little bit of ground nutmeg to a 50:50 mix of milk and cream
      - bring to boil & reduce for about 10 mins, stirring regularly, until nearly custard consistency
      - heat off & leave to infuse
  - name: mash
    ingredients:
      - potatoes
      - butter
      - salt
    steps:
      - prick potatoes
      - bake on a tray of salt at 180°C for about 45 mins
      - remove from oven, slice in half and let steam escape
      - while still warm, scoop out insides
      - gently melt butter
      - rice/ vegetable mill potato flesh into melted butter and mix around, then cover
      - pass butter & potato mix through drum sieve
      - add strained infusion to texture incrementally, mixing gently to incorporate
      - add salt to taste
      - add a little bit of butter to finish
