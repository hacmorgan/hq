yield: serves two (halved from Adam Liaw's recipe)
components:
  - name: dashi
    ingredients:
      - item: niboshi (dried anchovies)
        qty: 2
        unit: ea
        note: remove head and black intestines by pinching with fingers
      - item: water
        mass: 1000
        qty: 1
        unit: l
      - item: kombu (dried kelp)
        mass: 7
        qty: 1
        unit: ea
        note: small piece
      - item: dried shitake mushrooms
        qty: 2
        unit: ea
      - item: bonito flakes
        mass: 1
        note: a sprinkle; alternatively 1 tsp bonito soup stock (katsuo dashi)
    steps:
      - add niboshi, water, kombu and shitake to saucepan
      - bring to simmer
      - remove kombu when water starts to steam
      - add bonito flakes (if using bonito dashi)
      - turn off heat
      - let stand for 20 mins
      - strain
  - name: dashi seasoning
    ingredients:
      - item: soy
        mass: 16.5
        qty: 1.5
        unit: tbsp
      - item: mirin
        mass: 12
        qty: 1
        unit: tbsp
      - item: sugar
        mass: 5
        qty: 1
        unit: tsp
      - item: salt
        note: to taste
    steps:
      - add dashi seasoning and adjust taste
  - name: finishing
    steps:
      - add frozen udon cakes to simmering water until just separated
