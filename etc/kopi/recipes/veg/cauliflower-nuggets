ingredients:
  - item: cauliflower florets
    mass: 150
    basis: true
    note: cut into bite-sized pieces
components:
  - name: pun chun marinade
    ingredients:
      - item: pun chun
        mass: 30
      - item: soy
        mass: 15
      - item: honey
        mass: 30
  - name: dry dredge
    ingredients:
      - item: flour
        mass: 60
      - item: msg
        mass: 1
      - item: baking soda
        mass: 1
      - item: salt
        mass: 2.5
      - item: pepper
        mass: 0.5
        note: 50:50 black:white mix
  - name: cooking
    steps:
      - double dredge florets in pun chun marinade then dry dredge
      - fry at 150°C for a few mins until golden brown
      - serve with cauliflower yoghurt
