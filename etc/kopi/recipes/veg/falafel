ingredients:
  - item: dried chickpeas
    note: soaked overnight and drained
  - item: parsley
    qty: 1
    unit: cup
    note: roughly chopped
  - item: coriander leaves
    qty: 1
    unit: cup
    note: roughly chopped
  - item: spring onion
    qty: 6
    unit: ea
    note: white and light green sections, finely chopped
  - item: garlic clove
    qty: 2
    unit: ea
    note: minced
  - item: coriander powder
    qty: 0.5
    unit: tsp
  - item: salt
    qty: 3
    unit: tsp
  - item: baking powder
    qty: 0.5
    unit: tsp
  - item: flour
    qty: 4
    unit: tsp
  - item: water
    qty: 5
    unit: tbsp
steps:
  - soak dried chickpeas overnight
  - drain chickpeas
  - add all ingredients to food processor and blend until combined
