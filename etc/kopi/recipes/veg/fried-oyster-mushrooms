ingredients:
  - item: oyster mushrooms
    note: do not rinse; wipe with damp cloth to clean
components:
  - name: dry batter
    ingredients:
      - item: flour
        mass: 200
      - item: salt
        mass: 8
      - item: pepper mix
        mass: 3
        note: 1:2 white:black pepper
      - item: paprika
        mass: 3
    notes: |
      Commented-out options:
      - ground fennel seed
      - five spice
  - name: wet batter
    notes: |
      Combine dry batter and water in a 4:9 ratio
      i.e. dry batter weight * 9/4 = wet batter weight
  - name: cooking
    steps:
      - chop oyster mushrooms into thin tenders
      - double coat with batter (dry -> wet -> dry -> wet)
      - fry at 175°C
