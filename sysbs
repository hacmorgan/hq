function setup_dashboard
{
    local dashboard_dir="$hq/hq/gui/dashboard"

    say "Building Flutter web app..."
    "$dashboard_dir/build_dashboard.sh"

    say "Symlinking dashboard service files..."
    for service in dashboard-api.service dashboard-ui.service; do
        sudo ln -sf$verbose "$( realpath "$hq/etc/systemd/$service" )" /etc/systemd/system/
    done

    say "Reloading systemd daemon..."
    sudo systemctl daemon-reload

    say "Enabling and starting dashboard services..."
    sudo systemctl enable --now dashboard-api.service dashboard-ui.service
}


