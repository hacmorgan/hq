function install_zellij
{
    local install_prefix="${options_install_prefix:-$HOME/.local}"
    local bin_dir="$install_prefix/bin"
    mkdir -p "$bin_dir"

    # Detect architecture for the correct release tarball
    local arch
    arch="$(uname -m)"
    case "$arch" in
        x86_64)  arch_tag="x86_64-unknown-linux-musl" ;;
        aarch64) arch_tag="aarch64-unknown-linux-musl" ;;
        *)        die "Unsupported architecture: $arch" ;;
    esac

    # Resolve the latest release version from the GitHub API
    local version
    version="$(
        curl -sf https://api.github.com/repos/zellij-org/zellij/releases/latest \
            | grep '"tag_name"' \
            | sed 's/.*"tag_name": "\(.*\)".*/\1/'
    )"
    [[ -n "$version" ]] || die "Failed to fetch latest zellij version from GitHub API"

    say "Installing zellij ${version} (${arch_tag}) to ${bin_dir}"
    local url="https://github.com/zellij-org/zellij/releases/download/${version}/zellij-${arch_tag}.tar.gz"
    curl -L "$url" | tar -xzf - -C /tmp zellij
    mv /tmp/zellij "$bin_dir/zellij"
    chmod +x "$bin_dir/zellij"
    say "zellij ${version} installed to ${bin_dir}/zellij"
}


