function install_hq_claude
{
    local hq_claude="$hq/etc/claude"
    local plugin_dst="$HOME/.claude/plugins/hq"
    local marketplace="$HOME/.claude/plugins/.claude-plugin/marketplace.json"
    local settings="$HOME/.claude/settings.json"

    # Symlink hq claude plugin into place
    if (( options_dry_run )); then
        say "$hq_claude -> $plugin_dst"
    else
        if [[ -e "$plugin_dst" && ! -L "$plugin_dst" ]]; then
            if (( options_move_existing )); then
                mv $_verbose "$plugin_dst" "${plugin_dst}.old"
            else
                die "$plugin_dst exists and is not a symlink, use --move-existing to replace it"
            fi
        else
            rm -rf$verbose "$plugin_dst"
        fi
        ln -s$verbose "$( realpath "$hq_claude" )" "$plugin_dst"
    fi

    # Register in marketplace.json (add hq alongside existing plugins)
    if [[ -f "$marketplace" ]]; then
        python3 - "$marketplace" <<'PYEOF'
import json, sys
path = sys.argv[1]
data = json.loads(open(path).read())
plugins = data.setdefault("plugins", [])
if not any(p["name"] == "hq" for p in plugins):
    plugins.append({
        "name": "hq",
        "description": "Personal skills for hq",
        "category": "personal",
        "source": "./hq"
    })
    open(path, "w").write(json.dumps(data, indent=2) + "\n")
    print("[updated] marketplace.json (added hq)")
else:
    print("[skipped] marketplace.json (hq already present)")
PYEOF
    fi

    # Enable in settings.json
    if [[ -f "$settings" ]]; then
        python3 - "$settings" <<'PYEOF'
import json, sys
path = sys.argv[1]
data = json.loads(open(path).read())
enabled = data.setdefault("enabledPlugins", {})
changed = False
for key in ("hq", "hq@local"):
    if not enabled.get(key):
        enabled[key] = True
        changed = True
if changed:
    open(path, "w").write(json.dumps(data, indent=2) + "\n")
    print("[updated] settings.json (enabled hq plugin)")
else:
    print("[skipped] settings.json (hq already enabled)")
PYEOF
    fi
}


